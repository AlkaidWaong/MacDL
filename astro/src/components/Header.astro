---
const nav = [
  { href: "/", label: "首页" },
  {
    href: "https://apps.apple.com/cn/app/%E5%B0%8F%E9%B8%AD%E8%AE%A1%E6%97%B6-%E5%84%BF%E7%AB%A5%E5%8F%AF%E8%A7%86%E5%8C%96%E8%AE%A1%E6%97%B6%E5%99%A8/id6747744932",
    label: "小鸭计时"
  },
  { href: "https://kidcue.app/", label: "KidCue" },
  { href: "/search", label: "搜索" },
  { href: "/about", label: "关于" }
];
---

<header class="topbar">
  <div class="wrap">
    <div class="topbar-inner glass">
      <a class="brand" href="/">
        <img class="brand-logo" src="/favicon.ico" alt="" aria-hidden="true" />
        <span class="brand-title">MacAppHQ</span>
      </a>
      <nav class="nav" aria-label="Site">
        {nav.map((item) => (
          <a
            href={item.href}
            target={item.href.startsWith("http") ? "_blank" : undefined}
            rel={item.href.startsWith("http") ? "noopener noreferrer" : undefined}
          >
            {item.label}
          </a>
        ))}
      </nav>
    </div>
  </div>
</header>
