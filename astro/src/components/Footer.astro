---
import { getCollection } from "astro:content";
import { normalizeTag } from "../lib/tags";

const posts = await getCollection("posts", ({ data }) => !data.draft);
const catCounter = new Map<string, number>();
for (const post of posts) {
  for (const c of post.data.categories ?? []) {
    catCounter.set(c, (catCounter.get(c) ?? 0) + 1);
  }
}
const categories = [...catCounter.entries()]
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0], "zh-Hans-CN"))
  .map(([name, count]) => ({ name, count }));
const topCategories = categories.slice(0, 8);

const featuredSoftware = posts
  .filter((post) => (post.data.tags ?? []).includes("精选软件"))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 8);

const topicCounter = new Map<string, number>();
for (const post of posts) {
  for (const tag of post.data.tags ?? []) {
    const canonicalTag = normalizeTag(tag);
    if (canonicalTag === "精选软件") continue;
    topicCounter.set(canonicalTag, (topicCounter.get(canonicalTag) ?? 0) + 1);
  }
}

const coreTopics = [...topicCounter.entries()]
  .filter(([, count]) => count >= 3)
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0], "zh-Hans-CN"))
  .slice(0, 8)
  .map(([name, count]) => ({ name, count }));
---

<footer class="footer">
  <div class="wrap">
    <section class="glass footer-panel">
      <div class="footer-grid">
        <section>
          <h3>分类入口</h3>
          <div class="footer-cats">
            {topCategories.map((cat) => (
              <a href={`/category/${encodeURIComponent(cat.name)}`}>
                {cat.name} <span>({cat.count})</span>
              </a>
            ))}
            <a class="footer-more" href="/category">查看全部分类</a>
          </div>
        </section>

        <section>
          <h3>精选软件</h3>
          <ul>
            {featuredSoftware.map((post) => (
              <li>
                <a href={`/article/${post.data.urlSlug}`}>{post.data.title}</a>
              </li>
            ))}
            <li><a class="footer-more" href={`/tag/${encodeURIComponent("精选软件")}`}>查看更多精选软件</a></li>
          </ul>
        </section>

        <section>
          <h3>核心专题</h3>
          <ul>
            {coreTopics.map((topic) => (
              <li>
                <a href={`/tag/${encodeURIComponent(topic.name)}`}>
                  {topic.name} <span>({topic.count})</span>
                </a>
              </li>
            ))}
            <li><a class="footer-more" href="/category">查看更多专题分类</a></li>
          </ul>
        </section>

        <section>
          <h3>About</h3>
          <ul>
            <li><a href="/about">关于我们</a></li>
            <li><a href="/privacy-policy">隐私政策</a></li>
            <li><a href="/Risk-Warning">风险提示</a></li>
          </ul>
        </section>
      </div>

      <div class="footer-bottom">
        <span>© {new Date().getFullYear()} MacAppHQ</span>
        <span>Built with Astro</span>
      </div>
    </section>
  </div>
</footer>
