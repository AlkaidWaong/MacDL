---
import type { CollectionEntry } from "astro:content";
import { pickFirstBodyImage } from "../lib/cover";

type Props = {
  post: CollectionEntry<"posts">;
  showDescription?: boolean;
  showMeta?: boolean;
  showBadge?: boolean;
  headingTag?: "h2" | "h3";
  compact?: boolean;
};

const {
  post,
  showDescription = true,
  showMeta = true,
  showBadge = true,
  headingTag = "h2",
  compact = false
} = Astro.props;
const url = `/article/${post.data.urlSlug}`;
const categories = post.data.categories ?? [];
const title = post.data.title ?? "";
const primary = categories[0] ?? "";
const preview = post.data.quickTake?.trim() || post.data.description?.trim() || "";
const body = (post as unknown as { body?: string }).body ?? "";
const TitleTag = headingTag;

const coverSrc =
  post.data.heroImage?.trim() ||
  post.data.cover?.trim() ||
  pickFirstBodyImage(body) ||
  "";
---

<article class:list={["card", "post-card", compact && "post-card--compact"]}>
  <a class="post-card__link" href={url} aria-label={title} style="text-decoration:none;">
    <div class:list={["post-card__media", coverSrc ? "has-img" : ""]} aria-hidden="true">
      {coverSrc ? (
        <img class="post-card__img" src={coverSrc} alt="" loading="lazy" decoding="async" />
      ) : null}
      {showBadge && primary ? <div class="post-card__badge">{primary}</div> : null}
    </div>
    <div class="post-card__body">
      {showMeta ? (
        <div class="meta post-card__meta">
          {primary ? <span class="post-card__eyebrow">{primary}</span> : null}
          <time datetime={post.data.date.toISOString()}>
            {post.data.date.toISOString().slice(0, 10)}
          </time>
        </div>
      ) : null}
      <TitleTag class="post-card__title">{title}</TitleTag>
      {showDescription ? (
        preview ? (
          <p class="post-card__desc">{preview}</p>
        ) : (
          <p class="post-card__desc"> </p>
        )
      ) : null}
    </div>
  </a>
</article>
