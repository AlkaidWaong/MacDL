---
import { getCollection } from "astro:content";
import ArticleLayout from "../../layouts/ArticleLayout.astro";
import { pickFirstBodyImage, toAbsoluteUrl } from "../../lib/cover";

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.data.urlSlug },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const canonical = `https://www.macapphq.com/article/${post.data.urlSlug}`;
const site = Astro.site ?? new URL("https://www.macapphq.com");
const body = (post as unknown as { body?: string }).body ?? "";
const heroSrc =
  post.data.heroImage?.trim() ||
  post.data.cover?.trim() ||
  pickFirstBodyImage(body) ||
  "";
const ogImage = heroSrc ? toAbsoluteUrl(heroSrc, site) : undefined;
const category = post.data.categories?.[0];
const allPosts = await getCollection("posts", ({ data }) => !data.draft);
const relatedPosts = allPosts
  .filter((entry) => entry.id !== post.id)
  .map((entry) => {
    const sameCategory = (entry.data.categories ?? []).filter((c) =>
      (post.data.categories ?? []).includes(c)
    );
    const sameTags = (entry.data.tags ?? []).filter((t) => (post.data.tags ?? []).includes(t));
    return {
      entry,
      score: sameCategory.length * 3 + sameTags.length,
      note:
        sameCategory[0]
          ? `同属「${sameCategory[0]}」分类`
          : sameTags[0]
            ? `关联标签：${sameTags[0]}`
            : ""
    };
  })
  .filter((item) => item.score > 0)
  .sort(
    (a, b) =>
      b.score - a.score ||
      b.entry.data.date.getTime() - a.entry.data.date.getTime()
  )
  .slice(0, 3)
  .map(({ entry, note }) => ({
    title: entry.data.title,
    url: `/article/${entry.data.urlSlug}`,
    date: entry.data.date.toISOString(),
    category: entry.data.categories?.[0],
    note
  }));
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.data.title,
  description: post.data.description ?? "",
  datePublished: post.data.date.toISOString(),
  dateModified: post.data.updatedAt?.toISOString(),
  inLanguage: "zh-CN",
  mainEntityOfPage: canonical,
  image: ogImage ? [ogImage] : undefined,
  articleSection: category || undefined,
  publisher: {
    "@type": "Organization",
    name: "MacAppHQ",
    url: "https://www.macapphq.com",
    logo: {
      "@type": "ImageObject",
      url: "https://www.macapphq.com/favicon.ico"
    }
  }
};
const breadcrumbItems = [
  { name: "首页", item: "https://www.macapphq.com/" },
  ...(category
    ? [
        {
          name: category,
          item: `https://www.macapphq.com/category/${encodeURIComponent(category)}`
        }
      ]
    : []),
  { name: post.data.title, item: canonical }
];
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbItems.map((entry, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: entry.name,
    item: entry.item
  }))
};
const faqSchema = post.data.faqs?.length
  ? {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: post.data.faqs.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: item.answer
        }
      }))
    }
  : undefined;
---

<ArticleLayout
  title={post.data.title}
  description={post.data.description}
  date={post.data.date}
  categories={post.data.categories}
  quickTake={post.data.quickTake}
  canonical={canonical}
  image={ogImage}
  structuredData={[articleSchema, breadcrumbSchema, faqSchema].filter(Boolean)}
  heroImage={heroSrc || undefined}
  relatedPosts={relatedPosts}
>
  <Content />
</ArticleLayout>
