---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import Pagination from "../../components/Pagination.astro";
import { getCollection } from "astro:content";

const PAGE_SIZE = 12;

const allPosts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const categoryCount = new Map<string, number>();
for (const post of allPosts) {
  for (const c of post.data.categories ?? []) {
    categoryCount.set(c, (categoryCount.get(c) ?? 0) + 1);
  }
}

const categories = Array.from(categoryCount.entries())
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0], "zh-Hans-CN"))
  .map(([name, count]) => ({ name, count }));

const totalPages = Math.max(1, Math.ceil(allPosts.length / PAGE_SIZE));
const posts = allPosts.slice(0, PAGE_SIZE);
const canonical = "https://www.macapphq.com/category";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "首页",
      item: "https://www.macapphq.com/"
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "全部分类",
      item: canonical
    }
  ]
};

const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Mac 应用全部内容与分类导航",
  description:
    "浏览 MacAppHQ 全部文章内容，支持按分类切换，快速进入效率工具、开发工具、系统工具与影音娱乐等主题。",
  url: canonical,
  inLanguage: "zh-CN",
  about: categories.map((item) => item.name),
  numberOfItems: allPosts.length,
  mainEntity: {
    "@type": "ItemList",
    itemListElement: posts.map((post, index) => ({
      "@type": "ListItem",
      position: index + 1,
      url: `https://www.macapphq.com/article/${post.data.urlSlug}`,
      name: post.data.title
    }))
  }
};
---

<BaseLayout
  title="Mac 应用全部内容与分类导航 | MacAppHQ"
  description="浏览 MacAppHQ 全部文章内容，支持按分类切换，快速进入效率工具、开发工具、系统工具与影音娱乐等主题。"
  canonical={canonical}
  structuredData={[breadcrumbSchema, collectionSchema]}
>
  <div class="section-head">
    <h1>全部内容</h1>
  </div>

  <section class="glass index-overview index-overview--plain">
    <div class="index-overview__group">
      <div class="index-overview__head">
        <p class="index-overview__label">按分类切换</p>
      </div>
      <div class="index-overview__pills category-tabs">
        <a class="pill pill--active" href="/category">全部 <span>({allPosts.length})</span></a>
        {categories.map((category) => (
          <a class="pill" href={`/category/${encodeURIComponent(category.name)}`}>
            {category.name} <span>({category.count})</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="grid" aria-label="All category posts">
    {posts.map((post) => (
      <PostCard post={post} />
    ))}
  </section>

  <Pagination
    current={1}
    total={totalPages}
    hrefFor={(page) => (page === 1 ? "/category" : `/category/page/${page}`)}
  />
</BaseLayout>
