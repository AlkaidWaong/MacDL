---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("posts", ({ data }) => !data.draft);
const categoryCount = new Map();
for (const post of posts) {
  for (const c of post.data.categories ?? []) {
    categoryCount.set(c, (categoryCount.get(c) ?? 0) + 1);
  }
}
const categories = Array.from(categoryCount.entries()).sort((a, b) =>
  a[0].localeCompare(b[0], "zh-Hans-CN")
);
const canonical = "https://www.macapphq.com/category";
---

<BaseLayout title="分类 | MacAppHQ" description="按分类浏览文章" canonical={canonical}>
  <section class="glass page-head">
    <div class="page-crumb">
      <a href="/">首页</a>
      <span>/</span>
      <span>分类</span>
    </div>
    <p>分类索引 · 共 {categories.length} 个分类</p>
  </section>

  <section class="glass content" style="margin: 16px 0 36px;">
    <div class="meta" style="gap: 12px;">
      {categories.map(([name, count]) => (
        <a class="pill" href={`/category/${encodeURIComponent(name)}`}>
          {name} <span style="opacity: .55;">({count})</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
