---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import PostCard from "../../../../components/PostCard.astro";
import Pagination from "../../../../components/Pagination.astro";
import { getCollection } from "astro:content";
import { pickFirstAvailableEntryImage } from "../../../../lib/cover";

function parsePositiveInt(value) {
  const n = Number.parseInt(String(value), 10);
  return Number.isFinite(n) && n > 0 ? n : null;
}

export async function getStaticPaths() {
  const PAGE_SIZE = 12;
  const posts = await getCollection("posts", ({ data }) => !data.draft);
  const categorySet = new Set();
  for (const post of posts) {
    for (const c of post.data.categories ?? []) {
      categorySet.add(c);
    }
  }

  const paths = [];
  for (const categoryName of categorySet) {
    const total = posts.filter((p) =>
      (p.data.categories ?? []).includes(categoryName)
    ).length;
    const totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE));
    for (let page = 2; page <= totalPages; page++) {
      paths.push({
        params: {
          name: categoryName,
          page: String(page)
        }
      });
    }
  }
  return paths;
}

const nameParam = Astro.params.name ?? "";
const pageParam = parsePositiveInt(Astro.params.page);
let categoryName = nameParam;
try {
  categoryName = decodeURIComponent(nameParam);
} catch {}

if (!pageParam || pageParam <= 1) {
  return Astro.redirect(`/category/${encodeURIComponent(categoryName)}`, 301);
}

const all = await getCollection("posts", ({ data }) => !data.draft);
const filtered = all
  .filter((p) => (p.data.categories ?? []).includes(categoryName))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const categoryCount = new Map<string, number>();
for (const post of all) {
  for (const c of post.data.categories ?? []) {
    categoryCount.set(c, (categoryCount.get(c) ?? 0) + 1);
  }
}
const categoryTabs = Array.from(categoryCount.entries())
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0], "zh-Hans-CN"))
  .map(([name, count]) => ({ name, count }));

const PAGE_SIZE = 12;
const totalPages = Math.max(1, Math.ceil(filtered.length / PAGE_SIZE));
const page = Math.min(pageParam, totalPages);
const start = PAGE_SIZE * (page - 1);
const posts = filtered.slice(start, start + PAGE_SIZE);
const categoryOgImage = pickFirstAvailableEntryImage(filtered.slice(start));
const canonical = `https://www.macapphq.com/category/${encodeURIComponent(
  categoryName
)}/page/${page}`;
---

<BaseLayout
  title={`${categoryName} Mac 应用推荐（第 ${page} 页） | MacAppHQ`}
  description={`浏览 ${categoryName} 分类下的 Mac 应用推荐与评测内容，第 ${page} 页。`}
  canonical={canonical}
  robots="noindex,follow"
  image={categoryOgImage || undefined}
>
  <div class="section-head">
    <h1>{categoryName}</h1>
    <p class="section-note">第 {page} / {totalPages} 页</p>
  </div>

  <section class="glass category-overview">
    <div class="category-overview__intro">
      <p>当前是 {categoryName} 分类的分页内容。如果你想回到全站内容流，或切到别的分类，可以直接在下面切换。</p>
    </div>
    <div class="category-overview__topics">
      <div class="category-overview__head">
        <p class="category-overview__label">按分类切换</p>
        <p class="section-note">保持当前分类继续翻页，或者直接切到别的分类。</p>
      </div>
      <div class="topic-hub-pills category-tabs">
        <a class="pill" href="/category">全部 <span>({all.length})</span></a>
        {categoryTabs.map((category) => (
          <a
            class={`pill${category.name === categoryName ? " pill--active" : ""}`}
            href={`/category/${encodeURIComponent(category.name)}`}
          >
            {category.name} <span>({category.count})</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="grid" aria-label="Category posts">
    {posts.map((post) => (
      <PostCard post={post} />
    ))}
  </section>

  <Pagination
    current={page}
    total={totalPages}
    hrefFor={(p) =>
      p === 1
        ? `/category/${encodeURIComponent(categoryName)}`
        : `/category/${encodeURIComponent(categoryName)}/page/${p}`
    }
  />
</BaseLayout>
