---
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const PAGE_SIZE = 12;
  const posts = await getCollection("posts", ({ data }) => !data.draft);
  const categorySet = new Set<string>();
  for (const post of posts) {
    for (const c of post.data.categories ?? []) categorySet.add(c);
  }

  const paths = [];
  for (const name of categorySet) {
    const count = posts.filter((p) => (p.data.categories ?? []).includes(name)).length;
    const totalPages = Math.max(1, Math.ceil(count / PAGE_SIZE));
    for (let page = 2; page <= totalPages; page++) {
      paths.push({ params: { name, page: String(page) } });
    }
  }
  return paths;
}

const name = Astro.params.name ?? "";
const page = Astro.params.page ?? "";
return Astro.redirect(`/category/${encodeURIComponent(name)}/page/${encodeURIComponent(page)}`, 301);
---
