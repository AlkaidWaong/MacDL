---
import BaseLayout from "../../layouts/BaseLayout.astro";
const canonical = "https://www.macapphq.com/search";
---

<BaseLayout
  title="搜索 | MacAppHQ"
  description="搜索 MacAppHQ 里的应用测评、工具体验与工作流文章。"
  canonical={canonical}
  robots="noindex,follow"
>
  <h1 class="sr-only">搜索</h1>

  <section class="search-page">
    <div class="glass search-panel">
      <label class="search-panel__label meta" for="q">
      输入关键词（标题/摘要/标签）
      </label>
      <input
        id="q"
        class="search-panel__input"
        type="search"
        placeholder="例如：AI、邮件、剪贴板…"
      />
      <div id="result" class="search-results search-panel__results"></div>
    </div>
  </section>

  <script is:inline>
    const el = document.getElementById("q");
    const out = document.getElementById("result");
    const url = new URL(window.location.href);
    let data = null;
    async function load() {
      if (data) return data;
      const res = await fetch("/search-index.json", { cache: "force-cache" });
      data = await res.json();
      return data;
    }
    function render(items) {
      if (!items.length) {
        out.innerHTML = '<p class="search-results__empty">没有匹配结果</p>';
        return;
      }
      out.innerHTML =
        '<div class="search-results__list">' +
        items
          .slice(0, 30)
          .map(
            (it) =>
              `<a class="search-result" href="${it.url}">
                <div class="search-result__meta">${it.date || ""}</div>
                <div class="search-result__title">${it.title}</div>
                <p class="search-result__desc">${it.description || ""}</p>
              </a>`
          )
          .join("") +
        "</div>";
    }
    function score(q, it) {
      const s = (it.title + " " + (it.description || "") + " " + (it.tags || []).join(" ")).toLowerCase();
      return s.includes(q) ? 1 : 0;
    }
    async function onInput() {
      const q = (el.value || "").trim().toLowerCase();
      if (q) {
        url.searchParams.set("q", q);
      } else {
        url.searchParams.delete("q");
      }
      window.history.replaceState({}, "", url);
      if (!q) {
        out.innerHTML = '<p class="search-results__empty">输入关键词开始搜索</p>';
        return;
      }
      const items = await load();
      const matched = items
        .map((it) => ({ it, s: score(q, it) }))
        .filter((x) => x.s > 0)
        .map((x) => x.it);
      render(matched);
    }
    const initialQuery = (url.searchParams.get("q") || "").trim();
    el.value = initialQuery;
    out.innerHTML = '<p class="search-results__empty">输入关键词开始搜索</p>';
    el.addEventListener("input", onInput, { passive: true });
    if (initialQuery) onInput();
  </script>
</BaseLayout>
