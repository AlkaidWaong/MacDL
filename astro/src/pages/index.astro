---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import { getCollection } from "astro:content";
import { pickFirstAvailableEntryImage } from "../lib/cover";

const RECENT_POSTS_LIMIT = 12;

const all = await getCollection("posts", ({ data }) => !data.draft);
const featured = all
  .filter((post) => post.data.featured)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 4);
const posts = all.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const recentPosts = posts.slice(0, RECENT_POSTS_LIMIT);
const homeOgImage = pickFirstAvailableEntryImage(featured.length ? featured : posts);
const fixedTagEntries = [
  {
    href: `/tag/${encodeURIComponent("独立开发者App")}`,
    title: "想找值得长期留下来的小产品，从这里进",
    description: "优先看那些用过之后，真的容易留下来的独立开发者产品。",
    image: "/indie.png"
  },
  {
    href: `/tag/${encodeURIComponent("平替软件")}`,
    title: "不想一上来就花钱，可以先看这些平替",
    description: "先找价格更轻、体验又没差太远的替代方案。",
    image: "/altertive.png"
  }
];
const priorityReads = [
  {
    href: "/article/betterstage-for-mac",
    title: "BetterStage：每次切项目都要重摆桌面，就先看这篇",
    note: "每天切多个项目，还在双屏来回摆窗",
    description: "重点不是分屏，而是切项目时能不能把那套工作区一起带回来。"
  },
  {
    href: "/article/cc-switch-for-mac",
    title: "CC Switch：Claude Code、Codex 来回切久了，很需要这种统一入口",
    note: "已经在多套 CLI 和多家供应商之间切换",
    description: "如果你已经混用多套 CLI 和多家供应商，这篇会很快说明统一管理为什么省事。"
  },
  {
    href: "/article/codexbar-for-mac",
    title: "CodexBar：如果你也总惦记 Token 还剩多少，这篇会很有代入感",
    note: "同时挂着多个 Agent 会话，总怕额度见底",
    description: "它解决的不是好不好看，而是任务跑着跑着总惦记额度的分心感。"
  },
  {
    href: "/article/vidhub-v-1-7-8",
    title: "VidHub：如果你受够了文件夹找片，这篇更容易看懂它的价值",
    note: "片源散在 NAS、本地硬盘和网盘里",
    description: "它最打动人的地方，不是功能多，而是看片这条路径终于没那么碎了。"
  }
];
const homeCollectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Mac 应用推荐与评测：效率工具、开发工具、工作流指南",
  description:
    "MacAppHQ 持续更新 Mac 应用推荐、效率工具评测、开发工具体验、独立开发者 App 与平替软件清单，帮你更快找到真正值得长期使用的工具。",
  url: "https://www.macapphq.com/",
  inLanguage: "zh-CN",
  about: ["Mac 应用推荐", "Mac 效率工具", "Mac 开发工具", "工作流"],
  mainEntity: {
    "@type": "ItemList",
    itemListElement: recentPosts.map((post, index) => ({
      "@type": "ListItem",
      position: index + 1,
      url: `https://www.macapphq.com/article/${post.data.urlSlug}`,
      name: post.data.title
    }))
  }
};
---

<BaseLayout
  title="Mac 应用推荐与评测：效率工具、开发工具、工作流指南 | MacAppHQ"
  description="MacAppHQ 持续更新 Mac 应用推荐、效率工具评测、开发工具体验、独立开发者 App 与平替软件清单，帮你更快找到真正值得长期使用的工具。"
  keywords="Mac应用推荐,Mac效率工具,macOS软件,独立开发者App,平替软件,工作流"
  canonical="https://www.macapphq.com/"
  image={homeOgImage || undefined}
  structuredData={homeCollectionSchema}
>
  <section class="section-head section-head--hero">
    <h1>Mac 应用推荐、效率工具与开发工作流</h1>
    <p class="section-note">这里持续更新真正能留下来的 Mac 软件体验、工作流心得和开发工具判断，重点不是堆功能，而是帮你更快找到值得长期使用的工具。</p>
  </section>

  {featured.length ? (
    <>
      <div class="section-head">
        <h2>编辑精选</h2>
      </div>
      <section class="featured-grid" aria-label="Featured Posts">
        <div class="featured-col featured-col--left">
          {featured.slice(0, 2).map((post) => (
            <PostCard post={post} showDescription={false} showMeta={false} showBadge={false} headingTag="h3" />
          ))}
        </div>
        <div class="featured-col featured-col--center">
          {featured.slice(2, 3).map((post) => (
            <PostCard post={post} showDescription={false} showMeta={false} showBadge={false} headingTag="h3" />
          ))}
        </div>
        <div class="featured-col featured-col--right">
          {featured.slice(3, 4).map((post) => (
            <PostCard post={post} showDescription={false} showMeta={false} showBadge={false} headingTag="h3" />
          ))}
          {fixedTagEntries.map((entry) => (
            <article class="card post-card topic-card">
              <a class="post-card__link" href={entry.href} aria-label={entry.title} style="text-decoration:none;">
                <div class="post-card__media has-img" aria-hidden="true">
                  <img class="post-card__img" src={entry.image} alt="" loading="lazy" decoding="async" />
                </div>
                <div class="post-card__body">
                  <h3 class="post-card__title">{entry.title}</h3>
                  <p class="topic-card__desc">{entry.description}</p>
                </div>
              </a>
            </article>
          ))}
        </div>
      </section>
    </>
  ) : null}

  <section class="glass category-featured-block" aria-label="Priority reads">
    <div class="section-head">
      <h2>如果你第一次来，先看这几篇</h2>
      <p class="section-note">这几篇更容易先看出工具到底解决什么问题，也能更快判断值不值得装。</p>
    </div>
    <div class="search-results__list">
      {priorityReads.map((item) => (
        <a class="search-result" href={item.href}>
          <div class="search-result__meta">{item.note}</div>
          <div class="search-result__title">{item.title}</div>
          <p class="search-result__desc">{item.description}</p>
        </a>
      ))}
    </div>
  </section>

  <div class="section-head">
    <h2>最新更新</h2>
    <p class="section-note">先看最近更新的 12 篇；如果你想系统翻，可以再进归档或分类页继续找。</p>
  </div>
  <section class="grid" aria-label="Recent posts">
    {recentPosts.map((post) => (
      <PostCard post={post} />
    ))}
  </section>
</BaseLayout>
