---
import BaseLayout from "../layouts/BaseLayout.astro";
import reportData from "../data/seo-report.json";

const r = reportData;

const kwInTop3 = r.headline?.top3 ?? 0;
const kwInTop10 = r.headline?.top10 ?? 0;
const kwTotal = r.headline?.totalKeywords ?? r.queries?.length ?? 0;
const topKws = r.queries?.slice(0, 10) ?? [];
const actions = r.actions ?? [];
const ownerTodos = r.ownerTodos ?? [];
const generatedDate = r.generatedAt ? new Date(r.generatedAt) : null;
const generatedDateLabel = generatedDate ? generatedDate.toISOString().slice(0, 10) : r.generatedDate || "加载中";
const staleDays = generatedDate ? Math.floor((Date.now() - generatedDate.getTime()) / 86400000) : null;
const isStale = staleDays != null && staleDays >= 2;

function formatDelta(value, suffix = "") {
  if (value == null || Number.isNaN(value)) return "—";
  if (value === 0) return `0${suffix}`;
  return `${value > 0 ? "+" : ""}${value}${suffix}`;
}

function getTrend(headline) {
  const deltaTop10 = headline?.deltaTop10;
  if (deltaTop10 == null) return { emoji: "⚪️", text: "首份日报" };
  if (deltaTop10 > 0) return { emoji: "🟢", text: "上升" };
  if (deltaTop10 < 0) return { emoji: "🔴", text: "回撤" };
  return { emoji: "🟡", text: "持平" };
}

function movementLabel(query) {
  if (query.deltaPosition == null) return "新纳入";
  if (query.deltaPosition > 0) return `↑${query.deltaPosition}`;
  if (query.deltaPosition < 0) return `↓${Math.abs(query.deltaPosition)}`;
  return "—";
}

const trend = getTrend(r.headline);
const totalImp7d = r.timeline?.reduce((a, d) => a + d.impressions, 0) ?? 0;
---

<BaseLayout title={`SEO 日报 | MacAppHQ`} description="Google Search Console 搜索数据日报" canonical={`https://www.macapphq.com/seo-report`}>
  <article style="max-width: 960px; margin: 0 auto; padding: 2rem 1rem; line-height: 1.7; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;">
    <h1 style="font-size: 1.8rem; margin-bottom: 0.25rem;">MacAppHQ SEO 日报 — {generatedDateLabel}</h1>
    <p style="color: #888; margin-top: 0; font-size: 0.9rem;">
      数据源：Google Search Console | 周期：{r.period?.start ?? "-"} ~ {r.period?.end ?? "-"}
    </p>

    {isStale ? (
      <div style="background:#fff5e8; border:1px solid #f3d19c; border-radius:12px; padding:0.9rem 1rem; margin: 1rem 0;">
        <strong>⚠️ 报告已过期</strong>
        <div style="color:#8a5a00; font-size:0.92rem;">最近一次生成时间距今约 {staleDays} 天，说明自动生成链路可能没跑起来。</div>
      </div>
    ) : null}

    <hr style="margin: 1rem 0;" />

    {r.totals ? (
      <>
        <h2 style="font-size: 1.4rem;">🏆 首页战况</h2>
        <div style="background: linear-gradient(135deg, #f0f7ff 0%, #e6f0fa 100%); border-radius: 12px; padding: 1.5rem; margin: 0.75rem 0;">
          <p style="font-size: 1.6rem; font-weight: 700; margin: 0 0 0.5rem;">
            {trend.emoji} <strong>Google 首页关键词数 (Top 10)：{kwInTop10} 个</strong>
          </p>
          <p style="margin: 0.25rem 0;">
            Top 3：<strong>{kwInTop3}</strong> 个
            | Top 30：<strong>{kwTotal}</strong> 个
            | 较昨日：<strong>{formatDelta(r.headline?.deltaTop10, " 个")}</strong>
          </p>
          <p style="margin: 0.25rem 0;">
            今日趋势：<strong>{trend.text}</strong>
          </p>
          <hr style="margin: 0.75rem 0; border-color: rgba(0,0,0,0.1);" />
          <div style="display: flex; gap: 2rem; flex-wrap: wrap;">
            <div><span style="color: #666;">总曝光</span><br/><strong style="font-size: 1.3rem;">{(r.totals.impressions ?? 0).toLocaleString()}</strong><br/><span style="color:#777; font-size:0.85rem;">{formatDelta(r.headline?.deltaImpressions)}</span></div>
            <div><span style="color: #666;">总点击</span><br/><strong style="font-size: 1.3rem;">{(r.totals.clicks ?? 0).toLocaleString()}</strong><br/><span style="color:#777; font-size:0.85rem;">{formatDelta(r.headline?.deltaClicks)}</span></div>
            <div><span style="color: #666;">总 CTR</span><br/><strong style="font-size: 1.3rem;">{r.totals.ctr ?? 0}%</strong><br/><span style="color:#777; font-size:0.85rem;">{formatDelta(r.headline?.deltaCtr, "%")}</span></div>
            <div><span style="color: #666;">近 7 天曝光</span><br/><strong style="font-size: 1.3rem;">{totalImp7d.toLocaleString()}</strong></div>
          </div>
        </div>

        {r.timeline && r.timeline.length > 0 ? (
          <>
            <h2 style="font-size: 1.4rem;">📈 近7天趋势</h2>
            <div style="overflow-x: auto;">
              <table style="width:100%; border-collapse: collapse; font-size:0.9rem;">
                <thead>
                  <tr style="background: #f5f5f5;">
                    <th style="padding:0.5rem; border:1px solid #ddd;">日期</th>
                    <th style="padding:0.5rem; border:1px solid #ddd; text-align:right;">曝光</th>
                    <th style="padding:0.5rem; border:1px solid #ddd; text-align:right;">点击</th>
                    <th style="padding:0.5rem; border:1px solid #ddd; text-align:right;">CTR</th>
                  </tr>
                </thead>
                <tbody>
                  {r.timeline.map(t => (
                    <tr>
                      <td style="padding:0.5rem; border:1px solid #ddd;">{t.date}</td>
                      <td style="padding:0.5rem; border:1px solid #ddd; text-align:right;">{t.impressions.toLocaleString()}</td>
                      <td style="padding:0.5rem; border:1px solid #ddd; text-align:right;">{t.clicks.toLocaleString()}</td>
                      <td style="padding:0.5rem; border:1px solid #ddd; text-align:right;">{t.ctr}%</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </>
        ) : <p style="color:#888;">暂无趋势数据</p>}

        <h2 style="font-size: 1.4rem;">📋 关键词明细</h2>
        <div style="overflow-x: auto;">
          <table style="width:100%; border-collapse: collapse; font-size:0.85rem;">
            <thead>
              <tr style="background: #f5f5f5;">
                <th style="padding:0.4rem; border:1px solid #ddd;">排名</th>
                <th style="padding:0.4rem; border:1px solid #ddd; text-align:left;">关键词</th>
                <th style="padding:0.4rem; border:1px solid #ddd; text-align:right;">曝光</th>
                <th style="padding:0.4rem; border:1px solid #ddd; text-align:right;">点击</th>
                <th style="padding:0.4rem; border:1px solid #ddd; text-align:right;">CTR</th>
                <th style="padding:0.4rem; border:1px solid #ddd; text-align:center;">Δ排名</th>
                <th style="padding:0.4rem; border:1px solid #ddd; text-align:center;">首页?</th>
              </tr>
            </thead>
            <tbody>
              {r.queries?.slice(0, 20).map(q => (
                <tr style={q.position <= 10 ? "background: #f6fef6;" : ""}>
                  <td style="padding:0.4rem; border:1px solid #ddd; text-align:center;">#{q.position}</td>
                  <td style="padding:0.4rem; border:1px solid #ddd;">{q.keyword}</td>
                  <td style="padding:0.4rem; border:1px solid #ddd; text-align:right;">{q.impressions.toLocaleString()}</td>
                  <td style="padding:0.4rem; border:1px solid #ddd; text-align:right;">{q.clicks.toLocaleString()}</td>
                  <td style="padding:0.4rem; border:1px solid #ddd; text-align:right; color:{q.ctr >= 5 ? '#2a6' : q.ctr >= 3 ? '#a80' : '#c44'};">{q.ctr}%</td>
                  <td style="padding:0.4rem; border:1px solid #ddd; text-align:center;">{movementLabel(q)}</td>
                  <td style="padding:0.4rem; border:1px solid #ddd; text-align:center;">{q.position <= 10 ? "✅" : "❌"}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        {r.queries && r.queries.length > 20 ? <p style="color:#888; font-size:0.85rem;">仅显示 Top 20，共 {r.queries.length} 个追踪词</p> : null}

        {r.pages && r.pages.length > 0 ? (
          <>
            <h2 style="font-size: 1.4rem;">📄 Top 落地页</h2>
            <ol style="line-height: 1.8;">
              {r.pages.slice(0, 10).map(p => (
                <li>
                  <a href={p.page} style="text-decoration: none;">{p.page.replace(/^https:\/\/www\.macapphq\.com\/article\//, '').replace(/-/g, ' ')}</a>
                  <span style="color:#888; font-size:0.85rem;"> — {p.impressions} 次曝光, {p.clicks} 次点击, Δ曝光 {formatDelta(p.deltaImpressions)}</span>
                </li>
              ))}
            </ol>
          </>
        ) : null}

        <h2 style="font-size: 1.4rem;">🤖 GEO / AI 搜索战况</h2>
        <div style="background: #f9f6ff; border-radius: 10px; padding: 1rem; border: 1px solid #e8e0f0;">
          <p><strong>AI Overview 引用：</strong>当前仍需人工抽查目标词，暂未接入自动监测。</p>
          <p><strong>AI 引流量（GA4）：</strong>取决于 GA4 AI 来源渠道组是否已配置。</p>
          <p style="color:#888; font-size:0.85rem; margin-bottom: 0;">
            📌 如果这一块长期不变，优先处理下面的负责人待办，而不是继续在页面层改文案。
          </p>
        </div>

        <h2 style="font-size: 1.4rem;">📈 转化漏斗</h2>
        <div style="background: #fffef5; border-radius: 10px; padding: 1rem; border: 1px solid #f0ecc0;">
          <p><strong>SEO 自然流量（GA4 organic）：</strong>当前仍需在 GA4 中查看。</p>
          <p><strong>CTA 点击 / 注册（utm_medium=organic）：</strong>取决于 CTA 目标页和事件埋点是否统一。</p>
          <p style="color:#888; font-size:0.85rem; margin-bottom: 0;">
            📌 这块不再写死建议，状态直接交给下方待办和配置文件维护。
          </p>
        </div>

        <h2 style="font-size: 1.4rem;">🔧 今日动作</h2>
        {actions.length > 0 ? (
          <div style="display:grid; gap:0.9rem;">
            {actions.map(action => (
              <section style="border:1px solid #e7e7e7; border-radius:12px; padding:1rem 1rem 0.9rem;">
                <div style="font-weight:700; font-size:1rem;">{action.title}</div>
                <div style="color:#555; margin-top:0.3rem; font-size:0.92rem;">{action.detail}</div>
                {action.items && action.items.length > 0 ? (
                  <ul style="margin:0.7rem 0 0; padding-left:1.2rem; color:#666; font-size:0.9rem;">
                    {action.items.map(item => (
                      <li>
                        {item.keyword
                          ? `${item.keyword} · #${item.position} · CTR ${item.ctr}% · Δ曝光 ${formatDelta(item.deltaImpressions)}`
                          : `${item.page.split('/').pop()} · ${item.impressions} 曝光 · ${item.clicks} 点击`}
                      </li>
                    ))}
                  </ul>
                ) : null}
              </section>
            ))}
          </div>
        ) : <p style="color:#888;">暂无动作建议</p>}

        <h2 style="font-size: 1.4rem;">🚩 需要产品负责人处理的</h2>
        <div style="background: #fff0f0; border-radius: 10px; padding: 1rem; border: 1px solid #fcc;">
          {ownerTodos.length > 0 ? (
            <ul style="line-height: 1.8; margin: 0;">
              {ownerTodos.map(todo => (
                <li><strong>{todo.title}</strong> — {todo.detail}</li>
              ))}
            </ul>
          ) : <p style="margin:0;">当前没有未完成的负责人待办。</p>}
        </div>

        <hr style="margin: 1.5rem 0;" />
        <p style="color: #999; font-size: 0.75rem;">
          数据来源：Google Search Console API（sc-domain:macapphq.com）<br/>
          自动生成：{r.generatedAt ?? "-"} | 周期：{r.period?.start ?? "-"} ~ {r.period?.end ?? "-"}<br/>
          本页由 <code>scripts/generate-seo-report.js</code> 驱动，动作和负责人待办均来自报告 JSON。
        </p>
      </>
    ) : (
      <div style="background: #fff3cd; border-radius: 12px; padding: 2rem; text-align: center;">
        <h2>⏳ 报告尚未生成</h2>
        <p>请运行 <code>node scripts/generate-seo-report.js</code> 生成首份报告，然后重新部署。</p>
      </div>
    )}

  </article>
</BaseLayout>
