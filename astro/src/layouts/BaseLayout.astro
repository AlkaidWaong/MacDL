---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

type Props = {
  title?: string;
  description?: string;
  keywords?: string;
  canonical?: string;
  image?: string;
  ogType?: "website" | "article";
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
  robots?: string;
};

const {
  title = "MacAppHQ",
  description = "Mac apps and workflows.",
  keywords,
  canonical,
  image,
  ogType = "website",
  structuredData,
  robots = "index,follow"
} = Astro.props;

const SITE_URL = "https://www.macapphq.com";
const DEFAULT_OG_IMAGE = "/indie.png";

const toAbsoluteUrl = (value: string) => {
  if (value.startsWith("http://") || value.startsWith("https://")) return value;
  return new URL(value, SITE_URL).toString();
};

const pageCanonical = canonical
  ? toAbsoluteUrl(canonical)
  : new URL(Astro.url.pathname + Astro.url.search, SITE_URL).toString();

const pageImage = image ? toAbsoluteUrl(image) : toAbsoluteUrl(DEFAULT_OG_IMAGE);

const siteSchema = {
  "@type": "WebSite",
  name: "MacAppHQ",
  url: "https://www.macapphq.com",
  inLanguage: "zh-CN",
  potentialAction: {
    "@type": "SearchAction",
    target: "https://www.macapphq.com/search?q={search_term_string}",
    "query-input": "required name=search_term_string"
  }
};

const extraSchemas = Array.isArray(structuredData)
  ? structuredData
  : structuredData
    ? [structuredData]
    : [];

const graphSchemas = [siteSchema, ...extraSchemas].map((schema) => {
  const copy = { ...schema } as Record<string, unknown>;
  delete copy["@context"];
  return copy;
});

const jsonLdGraph = {
  "@context": "https://schema.org",
  "@graph": graphSchemas
};
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {keywords ? <meta name="keywords" content={keywords} /> : null}
    <meta name="robots" content={robots} />
    <link rel="canonical" href={pageCanonical} />

    <meta property="og:site_name" content="MacAppHQ" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageCanonical} />
    <meta property="og:image" content={pageImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={pageImage} />
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-N7QEYTRRV6"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {dataLayer.push(arguments);}
      gtag("js", new Date());
      gtag("config", "G-N7QEYTRRV6");
    </script>
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdGraph)} />
  </head>
  <body>
    <Header />
    <main class="wrap">
      <slot />
    </main>
    <Footer />
  </body>
</html>
