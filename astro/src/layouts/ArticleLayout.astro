---
import BaseLayout from "./BaseLayout.astro";

type Props = {
  title: string;
  description?: string;
  date: Date;
  categories?: string[];
  tags?: string[];
  quickTake?: string;
  canonical?: string;
  image?: string;
  heroImage?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
  breadcrumbs?: Array<{
    name: string;
    url?: string;
  }>;
  topicHubs?: Array<{
    title: string;
    href: string;
    note: string;
  }>;
  relatedPosts?: Array<{
    title: string;
    url: string;
    date: string;
    category?: string;
    note?: string;
  }>;
};

const {
  title,
  description,
  date,
  categories = [],
  tags = [],
  quickTake,
  canonical,
  image,
  heroImage,
  structuredData,
  breadcrumbs = [],
  topicHubs = [],
  relatedPosts = []
} = Astro.props;
const introLine = quickTake?.trim() || description?.trim();
---
<BaseLayout
  title={`${title} | MacAppHQ`}
  description={description}
  canonical={canonical}
  image={image}
  structuredData={structuredData}
  ogType="article"
>
  <section class="glass content article-shell">
    {breadcrumbs.length ? (
      <nav class="page-crumb article-crumb" aria-label="Breadcrumb">
        {breadcrumbs.map((item, index) => (
          <>
            {index > 0 ? <span aria-hidden="true">/</span> : null}
            {item.url ? <a href={item.url}>{item.name}</a> : <span>{item.name}</span>}
          </>
        ))}
      </nav>
    ) : null}
    {heroImage ? (
      <figure class="article-hero">
        <img src={heroImage} alt={title} loading="eager" decoding="async" />
      </figure>
    ) : null}
    <h1>{title}</h1>
    <div class="meta article-meta">
      <time datetime={date.toISOString()}>{date.toISOString().slice(0, 10)}</time>
      {categories.map((c) => (
        <a class="pill" href={`/category/${encodeURIComponent(c)}`}>{c}</a>
      ))}
    </div>
    {introLine ? (
      <section class="article-intro" aria-label="文章导语">
        <p>{introLine}</p>
      </section>
    ) : null}
    {tags.length ? (
      <section class="article-topics" aria-label="相关主题">
        <span class="article-topics__label">相关主题</span>
        <div class="article-topics__list">
          {tags.map((tag) => (
            <a class="pill" href={`/tag/${encodeURIComponent(tag)}`}>{tag}</a>
          ))}
        </div>
      </section>
    ) : null}
    {topicHubs.length ? (
      <section class="article-hubs" aria-label="继续按主题阅读">
        <div class="section-head">
          <h2>继续按主题往下看</h2>
          <p class="section-note">如果这篇文章已经对上你的问题，下一步更适合回到对应分类或专题继续看。</p>
        </div>
        <div class="search-results__list">
          {topicHubs.map((hub) => (
            <a class="search-result" href={hub.href}>
              <div class="search-result__meta">主题入口</div>
              <div class="search-result__title">{hub.title}</div>
              <p class="search-result__desc">{hub.note}</p>
            </a>
          ))}
        </div>
      </section>
    ) : null}
    <article class="article-prose">
      <slot />
    </article>
  </section>
  {relatedPosts.length ? (
    <section class="glass article-related-block" aria-label="相关文章">
      <section class="article-related">
        <h2>相关文章</h2>
        <div class="article-related__list">
          {relatedPosts.map((post) => (
            <a class="article-related__item" href={post.url}>
              <div class="article-related__meta">
                {post.category ? <span>{post.category}</span> : null}
                <time datetime={post.date}>{post.date.slice(0, 10)}</time>
              </div>
              <h3>{post.title}</h3>
              {post.note ? <p>{post.note}</p> : null}
            </a>
          ))}
        </div>
      </section>
    </section>
  ) : null}
</BaseLayout>
